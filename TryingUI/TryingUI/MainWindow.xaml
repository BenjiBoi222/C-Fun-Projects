<Window x:Class="TryingUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Secure Vault" Height="600" Width="1000"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A1C1E">
            <StackPanel Margin="20">
                <TextBlock Text="OPTIONS" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,40"/>

                <Button TextBlock.FontSize="20" Content="File" TextBlock.Foreground="Black" Margin="0,5" Padding="10" Click="Button_Click"/>
                <Button TextBlock.FontSize="20" Content="Server" Margin="0,5" TextBlock.Foreground="Black" Padding="10"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Name="MainContent" Background="White" Margin="20">
            <TextBlock Name="WelcomeText" Text="Select an option from the left." FontSize="24" Foreground="#333" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

    </Grid>
</Window>